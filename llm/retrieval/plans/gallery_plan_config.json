  "r_choices": [
    8
  ],
  "alpha_choices": [
    16
  ],
  "dropout_min": 0.0,
  "dropout_max": 0.1,
  "weight_decay_min": 0.0,
  "weight_decay_max": 0.1,
  "max_len": 512,
  "batch_size": 8,
  "grad_accum": 8,
  "target_modules": "q_proj,v_proj"
}