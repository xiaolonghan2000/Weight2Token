{
  "datasets": [
    "arc-challenge",
    "boolq",
    "gsm8k",
    "mbpp"
  ],
  "num_trials": 1000,
  "base_model": "meta-llama/Llama-3.2-3B",
  "seed": 42,
  "lr_min": 5e-06,
  "lr_max": 0.0005,
  "epochs_min": 1,
